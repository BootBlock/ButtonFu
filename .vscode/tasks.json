{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Drive.NET: manifest smoke - buttonfu-extension",
			"type": "shell",
			"command": "pwsh",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}/buttonfu-extension/tests/drive-net/Run-Manifest.ps1"
			],
			"problemMatcher": []
		},
		{
			"type": "npm",
			"script": "compile",
			"path": "buttonfu-extension",
			"problemMatcher": "$tsc",
			"label": "npm: compile - buttonfu-extension",
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"type": "npm",
			"script": "watch",
			"path": "buttonfu-extension",
			"problemMatcher": "$tsc-watch",
			"isBackground": true,
			"label": "npm: watch - buttonfu-extension",
			"presentation": {
				"reveal": "never"
			}
		},
		{
			"type": "npm",
			"script": "vsce-package",
			"path": "buttonfu-extension",
			"problemMatcher": [],
			"label": "npm: package - buttonfu-extension"
		}
	]
}